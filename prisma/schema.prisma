generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  programType           String
  eventName             String
  firstName             String
  lastName              String
  dob                   String
  gender                String
  tshirtSize            String?
  grade                 String?
  school                String?
  sports                String[]
  parentFirstName       String
  parentLastName        String
  parentPhone           String
  parentEmail           String
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  emergencyName         String?
  emergencyPhone        String?
  emergencyRelationship String?
  allergies             String?
  insuranceProvider     String?
  policyNumber          String?
  waiverConsent         Boolean  @default(false)
  status                String   @default("pending")
}

model JoinRequest {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  firstName     String
  lastName      String
  email         String
  path          String?
  sportInterest String?
  message       String?
  status        String   @default("new")
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
}

model CoachApplication {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  fullName               String
  email                  String
  phone                  String
  sports                 String[]
  experience             String
  availability           String[]
  motivation             String?
  backgroundCheckConsent Boolean  @default(false)
  backgroundCheckStatus  String   @default("pending")
  status                 String   @default("new")
}

model EquipmentRequest {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  organizationName String
  contactName      String
  email            String
  phone            String?
  type             String
  sportNeeds       String?
  numberOfAthletes String?
  message          String?
  status           String   @default("new")
}

model Sponsorship {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  sponsorName  String
  sponsorEmail String
  sponsorPhone String?
  tier         String
  amount       Int
  status       String   @default("pending")
}

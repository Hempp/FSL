generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Tournament & Clinic Registrations ──
model Registration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Program
  programType String // "tournament" | "clinic" | "both"
  eventName   String

  // Athlete
  firstName  String
  lastName   String
  dob        String
  gender     String
  tshirtSize String?
  grade      String?
  school     String?
  sports     String[] // ["Basketball", "Football", etc.]

  // Parent/Guardian
  parentFirstName String
  parentLastName  String
  parentPhone     String
  parentEmail     String
  address         String?
  city            String?
  state           String?
  zip             String?

  // Emergency Contact
  emergencyName         String?
  emergencyPhone        String?
  emergencyRelationship String?

  // Medical
  allergies         String?
  insuranceProvider  String?
  policyNumber      String?

  // Consent
  waiverConsent Boolean @default(false)

  // Status
  status String @default("pending") // pending, confirmed, cancelled
}

// ── Join / Volunteer Requests ──
model JoinRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  firstName     String
  lastName      String
  email         String
  path          String? // "partner" | "volunteer" | "donate"
  sportInterest String?
  message       String?

  status String @default("new")
}

// ── Contact Messages ──
model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name    String
  email   String
  subject String?
  message String

  read Boolean @default(false)
}

// ── Coach Applications ──
model CoachApplication {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  fullName    String
  email       String
  phone       String
  sports      String[] // ["Basketball", "Soccer", etc.]
  experience  String   // "2-5 years", "5-10 years", "10+ years"
  availability String[] // ["Weekday mornings", "Weekends", etc.]
  motivation  String?

  backgroundCheckConsent Boolean @default(false)
  backgroundCheckStatus  String  @default("pending") // pending, passed, failed

  status String @default("new") // new, reviewing, approved, rejected
}

// ── Equipment / Jersey Donation Requests ──
model EquipmentRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  organizationName String
  contactName      String
  email            String
  phone            String?
  type             String // "jerseys" | "equipment" | "both"
  sportNeeds       String?
  numberOfAthletes String?
  message          String?

  status String @default("new") // new, reviewing, fulfilled
}

// ── Mentor Coaching Sponsorships ──
model Sponsorship {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Sponsor info
  sponsorName  String
  sponsorEmail String
  sponsorPhone String?

  // Package
  tier    String // "single" | "monthly" | "weekly" | "intensive"
  amount  Int    // 75, 125, 225, 400

  // Status
  status String @default("pending") // pending, active, cancelled
}
